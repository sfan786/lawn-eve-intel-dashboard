# EVE Intel Dashboard — Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env

# Which deployment module to load (matches deployments/<name>.py)
DEPLOYMENT=lawn_perrigen

# Password to add/delete timers/entosis nodes/annotations/jump bridges.
# Kept as a FALLBACK when EVE SSO is not configured (below). If both this and
# SSO are unset, writes are disabled (the app uses a random per-process token).
TIMER_PASSWORD=

# ===== EVE SSO (optional, recommended) =====
# When all three EVE_* values are set, "Log in with EVE" becomes the primary
# auth for writes and the password above is just a fallback.
#
# Register an app at https://developers.eveonline.com/applications:
#   - Type: "Authentication Only" (no ESI scopes needed)
#   - Callback URL: https://<your-domain>/api/auth/sso/callback
#   NOTE: EVE allows ONE callback URL per app — register a SEPARATE app for
#   local dev with callback http://localhost:5000/api/auth/sso/callback.
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=

# Signs the session cookie. MUST be a persistent random string in prod, or
# every restart logs everyone out. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Who may write after SSO login. The primary alliance is always allowed; these
# add extra alliances and specific characters (FCs/guests). Comma-separated IDs.
AUTH_ALLOWED_ALLIANCE_IDS=
AUTH_ALLOWED_CHARACTER_IDS=

# Flask settings (rarely need changing)
FLASK_PORT=5000
FLASK_DEBUG=false
