# EVE Intel Dashboard — Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env

# Which deployment module to load (matches deployments/<name>.py)
DEPLOYMENT=lawn_perrigen

# Password required to add/delete timers in the timerboard UI.
# Set this to something only your alliance knows. If left unset/blank, timer
# and structure writes are disabled (the app uses a random per-process token).
TIMER_PASSWORD=

# Flask settings (rarely need changing)
FLASK_PORT=5000
FLASK_DEBUG=false
